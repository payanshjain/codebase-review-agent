# Groq — free tier LLM for answers (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace — local embeddings (no API key; first run downloads the model)
HUGGINGFACE_EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Chunking (tokens for SentenceSplitter)
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# Hybrid retrieval (vector + BM25 → fused top-k for the LLM)
RETRIEVAL_TOP_K=5
VECTOR_TOP_K=10
BM25_TOP_K=10
HYBRID_FUSION_MODE = reciprocal_rerank

# Persistence
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=codebase_qa_mvp
STORAGE_PERSIST_DIR=./data/storage

# Multi-repository management
REPOS_CLONE_DIR=./data/repos
REPOS_METADATA_FILE=./data/repositories.json

# AST-based chunking (max tokens per code chunk before sub-splitting)
AST_MAX_CHUNK_TOKENS=1500